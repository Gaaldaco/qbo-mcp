# ── QuickBooks Online credentials ─────────────────────────────────────────────

# Company/Realm ID (found in QBO URL: qbo.intuit.com/app/homepage?...realmId=XXXXXXXXXX)
QBO_REALM_ID=

# OAuth 2.0 Client credentials (from Intuit Developer Portal app settings)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# OAuth 2.0 tokens — get these from the OAuth 2.0 Playground in the Intuit dev portal
# Access token expires every 60 minutes; provide a refresh token for auto-renewal
QBO_ACCESS_TOKEN=
QBO_REFRESH_TOKEN=

# Environment: "sandbox" for testing, "production" for live data
QBO_ENVIRONMENT=sandbox

# ── Server config ──────────────────────────────────────────────────────────────
# Transport mode: "http" for Railway/remote, "stdio" for Claude Desktop local
TRANSPORT=http
PORT=3000
